{
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testEnvironment": "node",
    "testRegex": ".e2e-spec.ts$",
    "extensionsToTreatAsEsm": [".ts"],
    "transform": {
        "^.+\\.(t|j)s$": [
            "ts-jest",
            {
                "useESM": true,
                "tsconfig": {
                    "module": "ES2022",
                    "target": "ES2023"
                }
            }
        ]
    }
}
